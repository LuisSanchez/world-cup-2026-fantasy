{
  "name": "wc-fantasy",
  "private": true,
  "description": "Monorepo root — Vercel builds the frontend workspace",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev -w frontend",
    "build": "npm run build -w frontend",
    "start": "npm run start -w frontend",
    "lint": "npm run lint -w frontend",
    "test": "npm run test -w frontend",
    "test:coverage": "npm run test:coverage -w frontend"
  },
  "dependencies": {
    "next": "14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "engines": {
    "node": ">=18"
  }
}
