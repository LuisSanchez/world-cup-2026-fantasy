# Local: talk to FastAPI directly
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Vercel production (pick ONE approach) ---
#
# A) Direct to backend (simplest if CORS is set on FastAPI):
#    NEXT_PUBLIC_API_URL=https://YOUR-FASTAPI-HOST
#    (no /api suffix, no trailing slash)
#
# B) Same-origin proxy (recommended if you saw wc-fantasy-fs.vercel.app/api/... 404):
#    NEXT_PUBLIC_API_URL=          (empty — or omit and we auto-use proxy on Vercel)
#    BACKEND_URL=https://YOUR-FASTAPI-HOST
#    (BACKEND_URL is server-only; do NOT set it to your Vercel URL)
