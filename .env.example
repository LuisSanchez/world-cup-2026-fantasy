# Backend
SECRET_KEY=change-me-to-a-long-random-string
# SQLite (default / local file) OR Postgres (Neon, Railway, etc.)
# DATABASE_URL=sqlite:////app/data/wc_fantasy.db
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=sqlite:////app/data/wc_fantasy.db
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
SUPER_ADMIN_EMAIL=admin@localhost.dev
# Always admin in all environments (comma-separated)
ADMIN_EMAILS=admin@example.com,user@example.com
PREDICTION_LOCK_MINUTES=10

# Google OAuth (optional in local; required for production social login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Auto match results (API-Football / api-sports.io — free tier OK)
# https://www.api-football.com/ — header x-apisports-key
FOOTBALL_API_KEY=
FOOTBALL_LEAGUE_ID=1
FOOTBALL_SEASON=2026
RESULTS_FETCH_WINDOW_MINUTES=5
RESULTS_POLL_SECONDS=60
# Background worker + on-request auto sync. Default false (saves DB/API credits).
# Can also be toggled at runtime in Admin without redeploy.
CRON_JOBS_ENABLED=false

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
